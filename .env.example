# App
NEXT_PUBLIC_APP_URL=https://your-app.vercel.app

# Supabase
# Supabase -> Settings -> API -> Project URL
NEXT_PUBLIC_SUPABASE_URL=
# Supabase -> Settings -> API -> anon public
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Supabase -> Settings -> API -> service_role. Keep secret; never expose as NEXT_PUBLIC_*.
SUPABASE_SERVICE_ROLE_KEY=
# Supabase -> Settings -> Database -> Connection string (transaction/pooler mode)
DATABASE_URL=
# Supabase -> Settings -> Database -> Connection string (session/direct mode)
DIRECT_URL=

# Email (Resend)
RESEND_API_KEY=
EMAIL_FROM_ADDRESS=noreply@yourapp.com
EMAIL_FROM_NAME=YourApp
# Legacy Brevo webhook auth only
BREVO_WEBHOOK_KEY=

# Rate limiting (Upstash Redis or Vercel KV)
# Option A: Upstash Console -> database -> REST API
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
# Option B: Vercel Dashboard -> Storage -> KV -> .env.local
# KV_REST_API_URL=
# KV_REST_API_TOKEN=

# Cron jobs
# Random long secret passed as Authorization header.
CRON_SECRET=

# One-off superadmin creation script
SUPERADMIN_EMAIL=
SUPERADMIN_PASSWORD=
SUPERADMIN_NAME=Super Admin

# WhatsApp Business (optional addon)
WA_PHONE_NUMBER_ID=
WA_ACCESS_TOKEN=
WA_APP_SECRET=
WA_VERIFY_TOKEN=

# Analytics (PostHog)
NEXT_PUBLIC_POSTHOG_KEY=

# Error monitoring (Sentry)
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_ORG=
SENTRY_PROJECT=
SENTRY_AUTH_TOKEN=

# Monitoring repair automation
# GitHub issue tokens belong in n8n credentials, not in Vercel/app env.
# Use this only if a Sentry webhook receiver validates Sentry-Hook-Signature.
SENTRY_WEBHOOK_CLIENT_SECRET=

# E2E
PLAYWRIGHT_BASE_URL=
STORE_SLUG=
E2E_CREATE_ORDERS=false
E2E_ALLOW_PRODUCTION_ORDER=false
