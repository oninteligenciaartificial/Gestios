# ─── App ───────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=https://your-app.vercel.app

# ─── Supabase ──────────────────────────────────────────
# Supabase → Settings → API → Project URL
NEXT_PUBLIC_SUPABASE_URL=
# Supabase → Settings → API → anon public
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Supabase → Settings → API → service_role (keep secret)
SUPABASE_SERVICE_ROLE_KEY=
# Supabase → Settings → Database → Connection string (Transaction mode)
DATABASE_URL=
# Supabase → Settings → Database → Connection string (Session mode)
DIRECT_URL=

# ─── Email (Brevo) ─────────────────────────────────────
# Brevo → SMTP & API → API Keys
BREVO_API_KEY=
BREVO_SENDER_EMAIL=noreply@yourapp.com
BREVO_SENDER_NAME=YourApp
# Random secret — used to authenticate Brevo webhook calls
BREVO_WEBHOOK_KEY=

# ─── Rate Limiting (Vercel KV / Upstash) ───────────────
# Option A: Upstash direct — Upstash Console → your database → REST API
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
# Option B: Vercel KV — these are set automatically when you link a KV store
# in the Vercel Dashboard → Storage → KV → your-store → .env.local tab.
# KV_REST_API_URL=
# KV_REST_API_TOKEN=

# ─── Cron Jobs ─────────────────────────────────────────
# Random secret — passed as Authorization header for cron jobs
CRON_SECRET=

# ─── WhatsApp Business (optional addon) ────────────────
# Meta Business Dashboard → WhatsApp → API Setup
WA_PHONE_NUMBER_ID=
WA_ACCESS_TOKEN=
WA_APP_SECRET=
WA_VERIFY_TOKEN=

# ─── Error Monitoring (Sentry) ─────────────────────────
# Sentry → Project → Settings → Client Keys (DSN)
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_ORG=
SENTRY_PROJECT=
